{
  "name": "saas-maker",
  "version": "0.0.18-rc.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "bun test",
    "dev": "bun tsc --watch",
    "type-check": "tsgo -p tsconfig.test.json",
    "check": "bunx concurrently 'bun type-check' 'bun test'",
    "build": "bunx rimraf dist && tsc"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.js"
    },
    "./test-utils": {
      "types": "./dist/test-utils/index.d.ts",
      "import": "./dist/test-utils/index.js",
      "require": "./dist/test-utils/index.js"
    }
  },
  "keywords": [
    "saas",
    "utils"
  ],
  "author": "hey@wzulfikar.com",
  "license": "MIT",
  "description": "Collection of utilities for building SaaS applications",
  "devDependencies": {
    "@types/bun": "^1.2.12",
    "@typescript/native-preview": "^7.0.0-dev.20260323.1",
    "arktype": "^2.2.0",
    "lefthook": "^1.11.13",
    "typescript": "^5.8.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@types/react": "^19.1.4",
    "react": "^19.1.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wzulfikar/saas-maker.git"
  },
  "bugs": {
    "url": "https://github.com/wzulfikar/saas-maker/issues"
  },
  "homepage": "https://github.com/wzulfikar/saas-maker#readme",
  "dependencies": {
    "msw": "^2.12.2"
  }
}
